PORT=5000
NODE_ENV=production
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASS=
JWT_SECRET=
JWT_EXPIRES_IN=7d
CORS_ORIGINS=

# ── Stripe (Billing) ───────────────────────────────────────────────────
# Leave blank to disable billing — the API will return 503 from
# /billing/checkout, /billing/portal, /billing/sync until these are set.
# 1. Create a Product + recurring Price in the Stripe dashboard.
# 2. STRIPE_PRICE_ID = the price ID (price_xxx) for the paid plan.
# 3. STRIPE_SECRET_KEY = sk_live_… (or sk_test_… for staging).
# 4. STRIPE_WEBHOOK_SECRET = whsec_… from the webhook endpoint config.
#    Configure the webhook to POST to: https://<your-api>/api/billing/webhook
#    Required events: checkout.session.completed,
#                     customer.subscription.created,
#                     customer.subscription.updated,
#                     customer.subscription.deleted,
#                     invoice.payment_succeeded,
#                     invoice.payment_failed
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
