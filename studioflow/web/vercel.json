{
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "rewrites": [
    {
      "source": "/:school/:recital",
      "has": [{
        "type": "header",
        "key": "user-agent",
        "value": ".*(facebookexternalhit|facebot|Twitterbot|LinkedInBot|Slackbot|TelegramBot|Googlebot|bingbot|Discordbot|Applebot|WhatsApp).*"
      }],
      "destination": "https://abcd-danceclass-production.up.railway.app/api/public/:school/:recital/og"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
