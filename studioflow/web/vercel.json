{
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "rewrites": [
    {
      "source": "/:school/:recital",
      "missing": [{ "type": "query", "key": "_h" }],
      "destination": "/api/og?school=:school&recital=:recital"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
